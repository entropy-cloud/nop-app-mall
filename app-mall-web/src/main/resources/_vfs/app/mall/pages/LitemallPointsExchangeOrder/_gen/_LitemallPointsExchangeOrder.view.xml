<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="LitemallPointsExchangeOrder" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/app/mall/model/LitemallPointsExchangeOrder/LitemallPointsExchangeOrder.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--Id-->
                <col id="id" mandatory="true" sortable="true"/>

                <!--用户ID-->
                <col id="userId" mandatory="true" sortable="true"/>

                <!--积分商品ID-->
                <col id="pointsGoodsId" mandatory="true" sortable="true"/>

                <!--商品ID-->
                <col id="goodsId" mandatory="true" sortable="true"/>

                <!--SKU ID-->
                <col id="productId" sortable="true"/>

                <!--商品名称-->
                <col id="goodsName" sortable="true"/>

                <!--商品图片-->
                <col id="picUrl" sortable="true"/>

                <!--积分单价-->
                <col id="pointsPrice" mandatory="true" ui:number="true" sortable="true"/>

                <!--兑换数量-->
                <col id="quantity" mandatory="true" ui:number="true" sortable="true"/>

                <!--消耗总积分-->
                <col id="totalPoints" mandatory="true" ui:number="true" sortable="true"/>

                <!--收货地址ID-->
                <col id="addressId" sortable="true"/>

                <!--收货人-->
                <col id="consignee" sortable="true"/>

                <!--联系电话-->
                <col id="phone" sortable="true"/>

                <!--完整收货地址-->
                <col id="fullAddress" sortable="true"/>

                <!--兑换状态-->
                <col id="exchangeStatus" ui:number="true" sortable="true"/>

                <!--物流单号-->
                <col id="shipCode" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>

                <!--支付状态（组合兑换现金部分）-->
                <col id="payStatus" ui:number="true" sortable="true"/>

                <!--支付通道（组合兑换现金部分）-->
                <col id="payChannel" ui:number="true" sortable="true"/>

                <!--现金单价快照（组合兑换）-->
                <col id="cashPrice" ui:number="true" sortable="true"/>

                <!--余额支付金额（组合兑换现金部分）-->
                <col id="walletPayAmount" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-积分兑换订单表" i18n-en:title="">
            <layout>
 id[Id] userId[用户ID]
 pointsGoodsId[积分商品ID] goodsId[商品ID]
 productId[SKU ID] goodsName[商品名称]
 picUrl[商品图片] pointsPrice[积分单价]
 quantity[兑换数量] totalPoints[消耗总积分]
 addressId[收货地址ID] consignee[收货人]
 phone[联系电话] fullAddress[完整收货地址]
 exchangeStatus[兑换状态] shipCode[物流单号]
 remark[备注] payStatus[支付状态（组合兑换现金部分）]
 payChannel[支付通道（组合兑换现金部分）] cashPrice[现金单价快照（组合兑换）]
 walletPayAmount[余额支付金额（组合兑换现金部分）] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-积分兑换订单表" i18n-en:title="" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-积分兑换订单表" i18n-en:title="">
            <layout>
 userId[用户ID] pointsGoodsId[积分商品ID]
 goodsId[商品ID] productId[SKU ID]
 goodsName[商品名称] picUrl[商品图片]
 pointsPrice[积分单价] quantity[兑换数量]
 totalPoints[消耗总积分] addressId[收货地址ID]
 consignee[收货人] phone[联系电话]
 fullAddress[完整收货地址] exchangeStatus[兑换状态]
 shipCode[物流单号] remark[备注]
 payStatus[支付状态（组合兑换现金部分）] payChannel[支付通道（组合兑换现金部分）]
 cashPrice[现金单价快照（组合兑换）] walletPayAmount[余额支付金额（组合兑换现金部分）]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-积分兑换订单表" i18n-en:title=""/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPointsExchangeOrder__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPointsExchangeOrder__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:LitemallPointsExchangeOrder__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:LitemallPointsExchangeOrder__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:LitemallPointsExchangeOrder__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:LitemallPointsExchangeOrder__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:LitemallPointsExchangeOrder__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:LitemallPointsExchangeOrder__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:LitemallPointsExchangeOrder__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:LitemallPointsExchangeOrder__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>