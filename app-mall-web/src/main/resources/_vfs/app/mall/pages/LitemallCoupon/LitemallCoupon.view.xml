<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_LitemallCoupon.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id"/>
                <col id="name" label="名称"/>
                <col id="tag" label="标签"/>
                <col id="type" label="类型"/>
                <col id="discount" label="优惠金额" sortable="true"/>
                <col id="min" label="最低消费"/>
                <col id="total" label="数量" sortable="true"/>
                <col id="limit" label="限领数量"/>
                <col id="goodsType" label="商品范围"/>
                <col id="goodsValue" label="商品范围值"/>
                <col id="status" label="状态" sortable="true"/>
                <col id="timeType" label="时间类型"/>
                <col id="startTime" label="开始时间" sortable="true"/>
                <col id="endTime" label="结束时间" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout>
 name[优惠券名称] tag[优惠券标签]
 type[优惠券赠送类型] status[优惠券状态]
 desc[优惠券介绍]
 discount[优惠金额] min[最低消费金额]
 total[优惠券数量] limit[用户领券限制数量]
 goodsType[商品限制类型] goodsValue[商品限制值]
 timeType[有效时间限制] days[基于领取时间的有效天数]
 startTime[使用券开始时间] endTime[使用券截至时间]
 code[优惠券兑换码]
</layout>
        </form>
        <form id="edit">
            <layout>
 name[优惠券名称] tag[优惠券标签]
 type[优惠券赠送类型] status[优惠券状态]
 desc[优惠券介绍]
 discount[优惠金额] min[最低消费金额]
 total[优惠券数量] limit[用户领券限制数量]
 goodsType[商品限制类型] goodsValue[商品限制值]
 timeType[有效时间限制] days[基于领取时间的有效天数]
 startTime[使用券开始时间] endTime[使用券截至时间]
 code[优惠券兑换码]
</layout>
        </form>
        <form id="add" x:prototype="edit"/>
        <form id="query" editMode="query" title="查询条件">
            <layout>
                name type status
            </layout>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:override="bounded-merge">
                <action id="row-view-button" level="primary" label="查看">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="编辑">
                    <dialog page="update"/>
                </action>
                <action id="publish-button" label="上架" level="success">
                    <api url="@mutation:LitemallCoupon__publishCoupon">
                        <data>
                            <id>$id</id>
                        </data>
                    </api>
                    <confirmText>确认上架该优惠券吗？</confirmText>
                </action>
                <action id="unpublish-button" label="下架" level="warning">
                    <api url="@mutation:LitemallCoupon__unpublishCoupon">
                        <data>
                            <id>$id</id>
                        </data>
                    </api>
                    <confirmText>确认下架该优惠券吗？</confirmText>
                </action>
                <action id="row-delete-button" level="danger" label="删除">
                    <api url="@mutation:LitemallCoupon__delete?id=$id"/>
                    <confirmText>确认删除该优惠券吗？</confirmText>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>
