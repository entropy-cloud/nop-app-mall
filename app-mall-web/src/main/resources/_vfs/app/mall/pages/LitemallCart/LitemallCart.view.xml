<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_LitemallCart.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id"/>
                <col id="goodsName"/>
                <col id="goodsSn" label="商品编号"/>
                <col id="specifications" label="规格"/>
                <col id="price"/>
                <col id="number"/>
                <col id="checked"/>
                <col id="picUrl"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>