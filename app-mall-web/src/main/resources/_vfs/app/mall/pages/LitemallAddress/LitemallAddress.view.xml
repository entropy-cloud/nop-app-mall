<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_LitemallAddress.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="userId"/>
                <col id="name"/>
                <col id="tel"/>
                <col id="province"/>
                <col id="city"/>
                <col id="county"/>
                <col id="addressDetail"/>
                <col id="isDefault"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view">
            <layout>
                userId[用户ID] name[收货人]
                tel[手机号]
                province[省] city[市] county[区县]
                addressDetail[详细地址]
                isDefault[是否默认]
            </layout>
        </form>
        <form id="edit"/>
        <form id="add"/>
        <form id="query" layoutMode="horizontal">
            <layout>
                userId name
            </layout>
        </form>
    </forms>

    <pages>
        <crud name="main">
            <rowActions x:prototype-override="bounded-merge">
                <action id="row-view-button" level="primary" label="查看">
                    <dialog page="view"/>
                </action>
            </rowActions>
        </crud>
        <picker name="picker"/>
    </pages>
</view>