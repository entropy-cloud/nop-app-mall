<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="LitemallFlashSaleSession" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/app/mall/model/LitemallFlashSaleSession/LitemallFlashSaleSession.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--Id-->
                <col id="id" mandatory="true" sortable="true"/>

                <!--秒杀活动ID-->
                <col id="flashSaleId" mandatory="true" sortable="true"/>

                <!--场次开始时间-->
                <col id="sessionStart" mandatory="true" sortable="true"/>

                <!--场次结束时间-->
                <col id="sessionEnd" mandatory="true" sortable="true"/>

                <!--场次库存-->
                <col id="sessionStock" ui:number="true" sortable="true"/>

                <!--场次状态（0未开始/1进行中/2已结束）-->
                <col id="sessionStatus" ui:number="true" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
        <grid id="sub-grid-edit" x:prototype="list" editMode="list-edit">
            <cols>
                <col id="id" x:abstract="true"/>
                <col id="flashSaleId" x:abstract="true"/>
            </cols>
        </grid>
        <grid id="sub-grid-view" x:prototype="list" editMode="list-view">
            <cols>
                <col id="flashSaleId" x:abstract="true"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-秒杀场次表" i18n-en:title="">
            <layout>
 id[Id]
 flashSaleId[秒杀活动ID]
 sessionStart[场次开始时间]
 sessionEnd[场次结束时间]
 sessionStock[场次库存]
 sessionStatus[场次状态（0未开始/1进行中/2已结束）]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-秒杀场次表" i18n-en:title="" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-秒杀场次表" i18n-en:title="">
            <layout>
 flashSaleId[秒杀活动ID]
 sessionStart[场次开始时间]
 sessionEnd[场次结束时间]
 sessionStock[场次库存]
 sessionStatus[场次状态（0未开始/1进行中/2已结束）]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-秒杀场次表" i18n-en:title=""/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallFlashSaleSession__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallFlashSaleSession__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:LitemallFlashSaleSession__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:LitemallFlashSaleSession__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:LitemallFlashSaleSession__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:LitemallFlashSaleSession__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:LitemallFlashSaleSession__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:LitemallFlashSaleSession__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:LitemallFlashSaleSession__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:LitemallFlashSaleSession__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>