<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="LitemallPickupStore" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/app/mall/model/LitemallPickupStore/LitemallPickupStore.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--Id-->
                <col id="id" mandatory="true" sortable="true"/>

                <!--门店名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--门店地址-->
                <col id="address" mandatory="true" sortable="true"/>

                <!--联系人-->
                <col id="contact" mandatory="true" sortable="true"/>

                <!--联系电话-->
                <col id="phone" mandatory="true" sortable="true"/>

                <!--纬度-->
                <col id="latitude" ui:number="true" sortable="true"/>

                <!--经度-->
                <col id="longitude" ui:number="true" sortable="true"/>

                <!--营业时间-->
                <col id="openingHours" sortable="true"/>

                <!--启用状态-->
                <col id="status" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-自提门店表" i18n-en:title="">
            <layout>
 id[Id] name[门店名称]
 address[门店地址] contact[联系人]
 phone[联系电话] latitude[纬度]
 longitude[经度] openingHours[营业时间]
 status[启用状态] remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-自提门店表" i18n-en:title="" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-自提门店表" i18n-en:title="">
            <layout>
 name[门店名称]
 address[门店地址]
 contact[联系人]
 phone[联系电话]
 latitude[纬度]
 longitude[经度]
 openingHours[营业时间]
 status[启用状态]
 remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-自提门店表" i18n-en:title=""/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPickupStore__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPickupStore__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:LitemallPickupStore__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:LitemallPickupStore__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:LitemallPickupStore__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:LitemallPickupStore__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:LitemallPickupStore__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:LitemallPickupStore__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:LitemallPickupStore__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:LitemallPickupStore__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>