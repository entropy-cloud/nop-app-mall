<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="LitemallPromotionActivity" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/app/mall/model/LitemallPromotionActivity/LitemallPromotionActivity.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--Id-->
                <col id="id" mandatory="true" sortable="true"/>

                <!--活动名称-->
                <col id="name" mandatory="true" sortable="true"/>

                <!--折扣类型-->
                <col id="discountType" ui:number="true" sortable="true"/>

                <!--开始时间-->
                <col id="startTime" sortable="true"/>

                <!--结束时间-->
                <col id="endTime" sortable="true"/>

                <!--活动状态-->
                <col id="status" ui:number="true" sortable="true"/>

                <!--商品范围类型-->
                <col id="goodsScope" ui:number="true" sortable="true"/>

                <!--商品范围值(JSON)-->
                <col id="goodsScopeValue" sortable="true"/>

                <!--优先级-->
                <col id="priority" ui:number="true" sortable="true"/>

                <!--每人限参与次数(0不限)-->
                <col id="maxPerUser" ui:number="true" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-促销活动表（满减送）" i18n-en:title="">
            <layout>
 id[Id] name[活动名称]
 discountType[折扣类型] startTime[开始时间]
 endTime[结束时间] status[活动状态]
 goodsScope[商品范围类型] goodsScopeValue[商品范围值(JSON)]
 priority[优先级] maxPerUser[每人限参与次数(0不限)]
 remark[备注] 
</layout>
        </form>
        <form id="add" editMode="add" title="新增-促销活动表（满减送）" i18n-en:title="" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-促销活动表（满减送）" i18n-en:title="">
            <layout>
 name[活动名称] discountType[折扣类型]
 startTime[开始时间] endTime[结束时间]
 status[活动状态] goodsScope[商品范围类型]
 goodsScopeValue[商品范围值(JSON)] priority[优先级]
 maxPerUser[每人限参与次数(0不限)] remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-促销活动表（满减送）" i18n-en:title=""/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPromotionActivity__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPromotionActivity__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:LitemallPromotionActivity__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:LitemallPromotionActivity__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:LitemallPromotionActivity__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:LitemallPromotionActivity__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:LitemallPromotionActivity__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:LitemallPromotionActivity__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:LitemallPromotionActivity__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:LitemallPromotionActivity__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>