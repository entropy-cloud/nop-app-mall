<?xml version="1.0" encoding="UTF-8" ?>
<view x:schema="/nop/schema/xui/xview.xdef" bizObjName="LitemallPointsFlow" xmlns:i18n-en="i18n-en"
      xmlns:x="/nop/schema/xdsl.xdef" xmlns:j="j" xmlns:c="c" xmlns:gql="gql" xmlns:view-gen="view-gen" xmlns:xpl="xpl">

    <objMeta>/app/mall/model/LitemallPointsFlow/LitemallPointsFlow.xmeta</objMeta>

    <controlLib>/nop/web/xlib/control.xlib</controlLib>

    <x:gen-extends>
        <view-gen:DefaultViewGenExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:gen-extends>

    <x:post-extends>
        <view-gen:DefaultViewPostExtends xpl:lib="/nop/web/xlib/view-gen.xlib"/>
    </x:post-extends>

    <grids>
        <grid id="list" x:abstract="true">
            <cols>

                <!--Id-->
                <col id="id" mandatory="true" sortable="true"/>

                <!--积分账户ID-->
                <col id="accountId" mandatory="true" sortable="true"/>

                <!--用户ID-->
                <col id="userId" mandatory="true" sortable="true"/>

                <!--变动类型-->
                <col id="changeType" mandatory="true" ui:number="true" sortable="true"/>

                <!--变动数量-->
                <col id="changeAmount" mandatory="true" ui:number="true" sortable="true"/>

                <!--变动后余额-->
                <col id="balanceAfter" mandatory="true" ui:number="true" sortable="true"/>

                <!--来源类型-->
                <col id="sourceType" sortable="true"/>

                <!--来源业务ID-->
                <col id="sourceId" sortable="true"/>

                <!--备注-->
                <col id="remark" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list" x:prototype="list" x:abstract="true"/>
    </grids>

    <forms>
        <form id="view" editMode="view" title="查看-积分流水表" i18n-en:title="">
            <layout>
 id[Id]
 accountId[积分账户ID]
 userId[用户ID]
 changeType[变动类型]
 changeAmount[变动数量]
 balanceAfter[变动后余额]
 sourceType[来源类型]
 sourceId[来源业务ID]
 remark[备注]
</layout>
        </form>
        <form id="add" editMode="add" title="新增-积分流水表" i18n-en:title="" x:prototype="edit"/>
        <form id="edit" editMode="edit" title="编辑-积分流水表" i18n-en:title="">
            <layout>
 accountId[积分账户ID]
 userId[用户ID]
 changeType[变动类型]
 changeAmount[变动数量]
 balanceAfter[变动后余额]
 sourceType[来源类型]
 sourceId[来源业务ID]
 remark[备注]
</layout>
        </form>
        <form id="query" editMode="query" title="查询条件" i18n-en:title="Query Condition" x:abstract="true"/>
        <form id="asideFilter" editMode="query" x:abstract="true" submitOnChange="true"/>
        <form id="batchUpdate" editMode="edit" x:abstract="true" title="修改-积分流水表" i18n-en:title=""/>
    </forms>

    <pages>
        <crud name="view-list" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPointsFlow__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </crud>
        <crud name="main" grid="list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table autoFillHeight="true">
                <api url="@query:LitemallPointsFlow__findPage" gql:selection="{@pageSelection}"/>
            </table>
            <listActions>
                <action id="batch-delete-button" label="@i18n:common.batchDelete" batch="true">
                    <api url="@mutation:LitemallPointsFlow__batchDelete?ids=$ids"/>
                    <confirmText>@i18n:common.confirmBatchDelete</confirmText>
                </action>
                <action id="add-button" level="primary" label="@i18n:common.add" icon="fa fa-plus pull-left">
                    <dialog page="add"/>
                </action>
            </listActions>
            <rowActions>
                <action id="row-view-button" level="primary" label="@i18n:common.view">
                    <dialog page="view"/>
                </action>
                <action id="row-update-button" level="primary" label="@i18n:common.edit" x:abstract="true">
                    <dialog page="update"/>
                </action>
                <action id="row-delete-button" level="danger" label="@i18n:common.delete" x:abstract="true">
                    <api url="@mutation:LitemallPointsFlow__delete?id=$id"/>
                    <confirmText>@i18n:common.confirmDelete</confirmText>
                </action>
                <actionGroup id="row-more-button" label="@i18n:common.more" level="primary">
                    <action id="row-update-button" label="@i18n:common.edit">
                        <dialog page="update"/>
                    </action>
                    <action id="row-delete-button" label="@i18n:common.delete">
                        <api url="@mutation:LitemallPointsFlow__delete?id=$id"/>
                        <confirmText>@i18n:common.confirmDelete</confirmText>
                    </action>
                </actionGroup>
            </rowActions>
        </crud>
        <picker name="picker" grid="pick-list" asideFilterForm="asideFilter" filterForm="query" x:abstract="true">
            <table noOperations="true">
                <api url="@query:LitemallPointsFlow__findPage" gql:selection="{@pageSelection}"/>
            </table>
        </picker>
        <simple name="add" form="add">
            <api url="@mutation:LitemallPointsFlow__save/id"/>
        </simple>
        <simple name="view" form="view">
            <initApi url="@query:LitemallPointsFlow__get?id=$id" gql:selection="{@formSelection}"/>
        </simple>
        <simple name="update" form="edit">
            <initApi url="@query:LitemallPointsFlow__get?id=$id" gql:selection="{@formSelection}"/>
            <api url="@mutation:LitemallPointsFlow__update/id?id=$id" withFormData="true"/>
        </simple>
    </pages>
</view>