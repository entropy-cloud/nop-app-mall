<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_LitemallAd.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id"/>
                <col id="name" label="名称"/>
                <col id="link" label="链接"/>
                <col id="url" label="图片"/>
                <col id="position" label="位置"/>
                <col id="content" label="内容"/>
                <col id="enabled" label="启用"/>
                <col id="startTime" label="开始时间" sortable="true"/>
                <col id="endTime" label="结束时间" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>
