<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="_gen/_LitemallCollect.view.xml" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="id"/>
                <col id="userId" label="用户ID"/>
                <col id="type" label="类型"/>
                <col id="valueId" label="值ID"/>
                <col id="addTime" label="收藏时间" sortable="true"/>
            </cols>
        </grid>
        <grid id="pick-list"/>
    </grids>

    <forms>
        <form id="query" editMode="query" title="查询条件">
            <layout>
                userId type
            </layout>
        </form>
        <form id="view"/>
        <form id="edit"/>
        <form id="add"/>
    </forms>

    <pages>
        <crud name="main"/>
        <picker name="picker"/>
    </pages>
</view>
