<?xml version="1.0" encoding="UTF-8" ?>
<view x:extends="super" x:schema="/nop/schema/xui/xview.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <grids>
        <grid id="list">
            <cols x:override="bounded-merge">
                <col id="userName"/>
                <col id="nickName"/>
                <col id="phone"/>
                <col id="gender"/>
                <col id="userType"/>
                <col id="status"/>
                <col id="createTime"/>
                <col id="updateTime"/>
            </cols>
        </grid>
    </grids>

    <forms>
        <form id="edit" size="lg">
            <layout>
                userName[用户名] nickName[昵称]
                phone[电话] gender[性别]
                birthday[生日] email[邮件]
                status[用户状态] remark[备注]
            </layout>
        </form>

        <form id="view">
            <layout>
                ===========>baseInfo[基本信息]======
                userName[用户名] nickName[昵称]
                phone[电话] gender[性别]
                userType[用户类型] status[用户状态]
                email[邮件] birthday[生日]
                createTime[创建时间] updateTime[修改时间]
                remark[备注]
            </layout>
        </form>
    </forms>

</view>
