<?xml version="1.0" encoding="UTF-8" ?>
<beans x:schema="/nop/schema/beans.xdef" xmlns:x="/nop/schema/xdsl.xdef"
       xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <import resource="_dao.beans.xml"/>
    <import resource="_service.beans.xml"/>

    <bean id="app.mall.service.notification.MallNotificationService" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="app.mall.service.scheduler.MallJobInvoker" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="app.mall.service.pay.PaymentCallbackImpl" ioc:type="@bean:id" ioc:default="true"/>

    <bean id="payChannelRegistry" class="app.mall.service.pay.PayChannelRegistryImpl">
        <property name="channels">
            <ioc:collect-beans by-type="app.mall.pay.PayChannel" ioc:ignore-depends="true"/>
        </property>
    </bean>
</beans>
