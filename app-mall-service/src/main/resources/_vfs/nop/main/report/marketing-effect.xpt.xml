<?xml version="1.0" encoding="UTF-8" ?>
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <defaultFont fontColor="0x0" fontFamily="swiss" fontName="Helvetica" fontSize="11.0"/>

    <sheets>
        <sheet name="promotion">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>promotedOrderCount</value>
                            </cell>
                            <cell>
                                <value>totalGmv</value>
                            </cell>
                            <cell>
                                <value>totalDiscount</value>
                            </cell>
                            <cell>
                                <value>participantCount</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^promotionEffect!promotedOrderCount</value>
                            </cell>
                            <cell>
                                <value>*=^promotionEffect!totalGmv</value>
                            </cell>
                            <cell>
                                <value>*=^promotionEffect!totalDiscount</value>
                            </cell>
                            <cell>
                                <value>*=^promotionEffect!participantCount</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
        <sheet name="flashSale">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>dealOrderCount</value>
                            </cell>
                            <cell>
                                <value>totalGmv</value>
                            </cell>
                            <cell>
                                <value>participantCount</value>
                            </cell>
                            <cell>
                                <value>soldOutRate</value>
                            </cell>
                            <cell>
                                <value>rejectedCount</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^flashSaleEffect!dealOrderCount</value>
                            </cell>
                            <cell>
                                <value>*=^flashSaleEffect!totalGmv</value>
                            </cell>
                            <cell>
                                <value>*=^flashSaleEffect!participantCount</value>
                            </cell>
                            <cell>
                                <value>*=^flashSaleEffect!soldOutRate</value>
                            </cell>
                            <cell>
                                <value>*=^flashSaleEffect!rejectedCount</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
        <sheet name="pinTuan">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>openedGroups</value>
                            </cell>
                            <cell>
                                <value>successGroups</value>
                            </cell>
                            <cell>
                                <value>participantCount</value>
                            </cell>
                            <cell>
                                <value>totalGmv</value>
                            </cell>
                            <cell>
                                <value>successRate</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^pinTuanEffect!openedGroups</value>
                            </cell>
                            <cell>
                                <value>*=^pinTuanEffect!successGroups</value>
                            </cell>
                            <cell>
                                <value>*=^pinTuanEffect!participantCount</value>
                            </cell>
                            <cell>
                                <value>*=^pinTuanEffect!totalGmv</value>
                            </cell>
                            <cell>
                                <value>*=^pinTuanEffect!successRate</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
        <sheet name="coupon">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>claimedCount</value>
                            </cell>
                            <cell>
                                <value>usedCount</value>
                            </cell>
                            <cell>
                                <value>pulledGmv</value>
                            </cell>
                            <cell>
                                <value>usedRate</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^couponUsage!claimedCount</value>
                            </cell>
                            <cell>
                                <value>*=^couponUsage!usedCount</value>
                            </cell>
                            <cell>
                                <value>*=^couponUsage!pulledGmv</value>
                            </cell>
                            <cell>
                                <value>*=^couponUsage!usedRate</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>
</workbook>
