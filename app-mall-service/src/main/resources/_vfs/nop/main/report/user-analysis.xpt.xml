<?xml version="1.0" encoding="UTF-8" ?>
<workbook x:schema="/nop/schema/excel/workbook.xdef" xmlns:x="/nop/schema/xdsl.xdef">

    <defaultFont fontColor="0x0" fontFamily="swiss" fontName="Helvetica" fontSize="11.0"/>

    <sheets>
        <sheet name="retention">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>dateLabel</value>
                            </cell>
                            <cell>
                                <value>cohortSize</value>
                            </cell>
                            <cell>
                                <value>d1</value>
                            </cell>
                            <cell>
                                <value>d7</value>
                            </cell>
                            <cell>
                                <value>d30</value>
                            </cell>
                            <cell>
                                <value>d1Rate</value>
                            </cell>
                            <cell>
                                <value>d7Rate</value>
                            </cell>
                            <cell>
                                <value>d30Rate</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^retentionList!dateLabel</value>
                            </cell>
                            <cell>
                                <value>*=^retentionList!cohortSize</value>
                            </cell>
                            <cell>
                                <value>*=^retentionList!d1</value>
                            </cell>
                            <cell>
                                <value>*=^retentionList!d7</value>
                            </cell>
                            <cell>
                                <value>*=^retentionList!d30</value>
                            </cell>
                            <cell>
                                <value>*=^retentionList!d1Rate</value>
                            </cell>
                            <cell>
                                <value>*=^retentionList!d7Rate</value>
                            </cell>
                            <cell>
                                <value>*=^retentionList!d30Rate</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
        <sheet name="rfm">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>segment</value>
                            </cell>
                            <cell>
                                <value>userCount</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^rfmList!segment</value>
                            </cell>
                            <cell>
                                <value>*=^rfmList!userCount</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
        <sheet name="lifecycle">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>segment</value>
                            </cell>
                            <cell>
                                <value>userCount</value>
                            </cell>
                            <cell>
                                <value>percent</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^lifecycleList!segment</value>
                            </cell>
                            <cell>
                                <value>*=^lifecycleList!userCount</value>
                            </cell>
                            <cell>
                                <value>*=^lifecycleList!percent</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
        <sheet name="repurchase">
            <table>
                <rows>
                    <row>
                        <cells>
                            <cell>
                                <value>dateLabel</value>
                            </cell>
                            <cell>
                                <value>paidUsers</value>
                            </cell>
                            <cell>
                                <value>repurchaseUsers</value>
                            </cell>
                            <cell>
                                <value>rate</value>
                            </cell>
                        </cells>
                    </row>
                    <row>
                        <cells>
                            <cell>
                                <value>*=^repurchaseList!dateLabel</value>
                            </cell>
                            <cell>
                                <value>*=^repurchaseList!paidUsers</value>
                            </cell>
                            <cell>
                                <value>*=^repurchaseList!repurchaseUsers</value>
                            </cell>
                            <cell>
                                <value>*=^repurchaseList!rate</value>
                            </cell>
                        </cells>
                    </row>
                </rows>
            </table>
        </sheet>
    </sheets>
</workbook>
