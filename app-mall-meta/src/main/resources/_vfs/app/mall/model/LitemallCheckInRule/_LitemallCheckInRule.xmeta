        </prop>
        <prop name="updateTime" displayName="更新时间" propId="6" queryable="true" sortable="true" insertable="true"
              updatable="true" internal="true" ui:show="X">
            <schema domain="updateTime" type="java.time.LocalDateTime"/>
        </prop>
    </props>
</meta>